{
  "name": "fortress-chat-mac",
  "version": "0.3.7",
  "private": true,
  "description": "FortressChat for Mac — local-first AI chat with US-only model governance",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20 <23"
  },
  "installConfig": {
    "allowScripts": [
      "electron",
      "esbuild",
      "fsevents"
    ]
  },
  "scripts": {
    "postinstall": "git submodule update --init --recursive && node scripts/ensure-electron.mjs",
    "sync:extension": "node scripts/sync-extension-media.mjs",
    "sync": "node scripts/sync-renderer.mjs",
    "prebuild": "node scripts/ensure-electron.mjs && node scripts/check-vendor.mjs && node scripts/check-extension-parity.mjs",
    "build": "npm run sync && node esbuild.mjs && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prestart": "node scripts/ensure-electron.mjs",
    "start": "npm run build && electron .",
    "smoke": "npm run build && electron . --smoke",
    "dist": "npm run build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
