{
  "name": "fortress-chat-mac",
  "version": "0.3.2",
  "private": true,
  "description": "FortressChat for Mac — local-first AI chat with US-only model governance",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "git submodule update --init --recursive",
    "sync": "node scripts/sync-renderer.mjs",
    "prebuild": "node scripts/check-vendor.mjs",
    "build": "npm run sync && node esbuild.mjs && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "npm run build && electron .",
    "smoke": "npm run build && electron . --smoke",
    "dist": "npm run build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
